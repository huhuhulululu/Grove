{
  "name": "grovekit",
  "version": "0.1.0",
  "description": "A local-first, tool-agnostic game layer that makes AI-assisted coding fun and nudges good engineering habits.",
  "type": "module",
  "license": "MIT",
  "author": "Grove contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/grovekit/grove"
  },
  "homepage": "https://github.com/grovekit/grove#readme",
  "bugs": {
    "url": "https://github.com/grovekit/grove/issues"
  },
  "keywords": [
    "cli",
    "gamification",
    "ai-coding",
    "tui",
    "developer-tools",
    "xp",
    "git-hooks"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sq": "./dist/cli/sq.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sq": "tsx src/cli/sq.ts"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.29",
    "@vitest/coverage-v8": "^2.1.9",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
